{
    "name": "Raster Algebra Test",
    "provider":{
        "type":"docker",
        "concurrency":5,
        "queue": "docker-local"
    },
    "plugins": ["aggregator-plugin-manifest-local-docker.json"],
    "event":{
        "compute-manifests":[
            "raster-algebra-compute-manifest1.json",
            "raster-algebra-compute-manifest2.json",
            "raster-algebra-compute-manifest3.json",
            "raster-algebra-compute-manifest4.json"
        ]
    },
    "secrets-manager":{
        "type": "env",
        "secrets":{
            "secretsmanager:AWS_ACCESS_KEY_ID::":"AWS_ACCESS_KEY_ID",
            "secretsmanager:AWS_SECRET_ACCESS_KEY::":"AWS_SECRET_ACCESS_KEY"
        }
    }

}